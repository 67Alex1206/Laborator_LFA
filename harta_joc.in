[Sigma]
w,a,s,d,p,e
[End]

[Gamma]
$,cheie
[End]

[InitStack]
$
[End]

[States]
intrare
coridor
camera_stanga
camera_dreapta
sala_tronului
*libertate
[End]

[Delta]
# Navigare intre camere
intrare,w,epsilon,coridor,epsilon
intrare,a,epsilon,intrare,epsilon
intrare,s,epsilon,intrare,epsilon
intrare,d,epsilon,intrare,epsilon
intrare,p,epsilon,intrare,epsilon
intrare,e,epsilon,intrare,epsilon

coridor,s,epsilon,intrare,epsilon
coridor,a,epsilon,camera_stanga,epsilon
coridor,d,epsilon,camera_dreapta,epsilon
coridor,w,epsilon,sala_tronului,epsilon
coridor,p,epsilon,coridor,epsilon
coridor,e,epsilon,coridor,epsilon

camera_stanga,d,epsilon,coridor,epsilon
camera_stanga,w,epsilon,camera_stanga,epsilon
camera_stanga,a,epsilon,camera_stanga,epsilon
camera_stanga,s,epsilon,camera_stanga,epsilon
camera_stanga,p,epsilon,camera_stanga,epsilon
camera_stanga,e,epsilon,camera_stanga,epsilon

camera_dreapta,a,epsilon,coridor,epsilon
camera_dreapta,p,cheie,camera_dreapta,cheie
camera_dreapta,p,epsilon,camera_dreapta,cheie
camera_dreapta,w,epsilon,camera_dreapta,epsilon
camera_dreapta,s,epsilon,camera_dreapta,epsilon
camera_dreapta,d,epsilon,camera_dreapta,epsilon
camera_dreapta,e,epsilon,camera_dreapta,epsilon

sala_tronului,s,epsilon,coridor,epsilon
sala_tronului,e,cheie,libertate,epsilon
sala_tronului,w,epsilon,sala_tronului,epsilon
sala_tronului,a,epsilon,sala_tronului,epsilon
sala_tronului,d,epsilon,sala_tronului,epsilon
sala_tronului,p,epsilon,sala_tronului,epsilon

# Finalizare
libertate,w,epsilon,libertate,epsilon
libertate,a,epsilon,libertate,epsilon
libertate,s,epsilon,libertate,epsilon
libertate,d,epsilon,libertate,epsilon
libertate,p,epsilon,libertate,epsilon
libertate,e,epsilon,libertate,epsilon
[End]